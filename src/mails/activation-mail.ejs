<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Activate Your Learnify Account</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f4f7fb;
      font-family: Arial, Helvetica, sans-serif;
    "
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="background-color: #f4f7fb; padding: 40px 20px"
    >
      <tr>
        <td align="center">
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #ffffff;
              border-radius: 16px;
              overflow: hidden;
              box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            "
          >
            <!-- Header -->
            <tr>
              <td
                align="center"
                style="background: #2563eb; padding: 40px 20px"
              >
                <h1
                  style="
                    margin: 0;
                    color: #ffffff;
                    font-size: 32px;
                    font-weight: 700;
                  "
                >
                  Learnify
                </h1>
                <p style="margin: 10px 0 0; color: #dbeafe; font-size: 16px">
                  Learn Smarter. Grow Faster.
                </p>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td style="padding: 40px">
                <h2 style="margin: 0 0 20px; color: #111827; font-size: 24px">
                  Welcome, <%= user.name %> 👋
                </h2>

                <p
                  style="
                    margin: 0 0 20px;
                    color: #4b5563;
                    font-size: 16px;
                    line-height: 1.8;
                  "
                >
                  Thank you for joining Learnify. We're excited to help you
                  achieve your learning goals through our modern and interactive
                  learning platform.
                </p>

                <p
                  style="
                    margin: 0 0 30px;
                    color: #4b5563;
                    font-size: 16px;
                    line-height: 1.8;
                  "
                >
                  To complete your registration and activate your account,
                  please use the verification code below:
                </p>

                <!-- Activation Code -->
                <div style="text-align: center; margin: 30px 0">
                  <div
                    style="
                      display: inline-block;
                      background: #eff6ff;
                      color: #2563eb;
                      font-size: 32px;
                      font-weight: 700;
                      letter-spacing: 8px;
                      padding: 18px 32px;
                      border-radius: 12px;
                      border: 2px dashed #2563eb;
                    "
                  >
                    <%= activationCode %>
                  </div>
                </div>

                <p
                  style="
                    margin: 30px 0 0;
                    color: #6b7280;
                    font-size: 14px;
                    line-height: 1.8;
                  "
                >
                  This verification code will expire shortly for security
                  purposes. If you did not create a Learnify account, you can
                  safely ignore this email.
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style="background: #f9fafb; padding: 30px; text-align: center"
              >
                <p style="margin: 0; color: #6b7280; font-size: 14px">
                  © <%= new Date().getFullYear() %> Learnify. All rights
                  reserved.
                </p>

                <p style="margin: 10px 0 0; color: #9ca3af; font-size: 12px">
                  Empowering learners worldwide with quality education.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
